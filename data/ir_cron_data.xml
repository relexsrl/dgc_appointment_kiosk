<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <record id="cron_close_pending_turns" model="ir.cron">
            <field name="name">DGC: Cerrar turnos pendientes</field>
            <field name="model_id" ref="model_dgc_appointment_turn"/>
            <field name="state">code</field>
            <field name="code">model._cron_close_pending_turns()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="nextcall">2026-03-19 03:00:00</field>
            <field name="active">True</field>
        </record>
        <!-- Legacy cleanup cron: rate limiting now uses in-memory dict.
             Enable once after migration to purge leftover dgc_kiosk.rl.* ICP keys. -->
        <record id="ir_cron_cleanup_rate_limit_keys" model="ir.cron">
            <field name="name">DGC: Limpiar claves de rate limit (legacy)</field>
            <field name="model_id" ref="model_dgc_appointment_turn"/>
            <field name="state">code</field>
            <field name="code">model._cron_cleanup_rate_limit_keys()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="active" eval="False"/>
            <field name="nextcall">2026-01-01 03:05:00</field>
        </record>
    </data>
</odoo>
