<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- List View -->
    <record id="dgc_appointment_derivation_view_list" model="ir.ui.view">
        <field name="name">dgc.appointment.derivation.list</field>
        <field name="model">dgc.appointment.derivation</field>
        <field name="arch" type="xml">
            <list>
                <field name="turn_id"/>
                <field name="from_area_id"/>
                <field name="to_area_id"/>
                <field name="reason"/>
                <field name="user_id"/>
                <field name="derivation_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_dgc_appointment_derivation_form" model="ir.ui.view">
        <field name="name">dgc.appointment.derivation.form</field>
        <field name="model">dgc.appointment.derivation</field>
        <field name="arch" type="xml">
            <form create="false" edit="false">
                <sheet>
                    <group>
                        <group>
                            <field name="turn_id"/>
                            <field name="from_area_id"/>
                            <field name="to_area_id"/>
                        </group>
                        <group>
                            <field name="user_id"/>
                            <field name="derivation_date"/>
                            <field name="new_turn_id"/>
                        </group>
                    </group>
                    <group>
                        <field name="reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Search View -->
    <record id="dgc_appointment_derivation_view_search" model="ir.ui.view">
        <field name="name">dgc.appointment.derivation.search</field>
        <field name="model">dgc.appointment.derivation</field>
        <field name="arch" type="xml">
            <search>
                <field name="turn_id"/>
                <field name="from_area_id"/>
                <field name="to_area_id"/>
                <field name="user_id"/>
                <filter name="today" string="Hoy"
                        domain="[('derivation_date', '&gt;=', context_today().strftime('%Y-%m-%d'))]"/>
                <group>
                    <filter name="group_from" string="Área origen"
                            context="{'group_by': 'from_area_id'}"/>
                    <filter name="group_to" string="Área destino"
                            context="{'group_by': 'to_area_id'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- Action -->
    <record id="action_dgc_appointment_derivation" model="ir.actions.act_window">
        <field name="name">Derivaciones</field>
        <field name="res_model">dgc.appointment.derivation</field>
        <field name="view_mode">list,form</field>
        <field name="search_view_id" ref="dgc_appointment_derivation_view_search"/>
        <field name="context">{'search_default_today': 1}</field>
    </record>

</odoo>
