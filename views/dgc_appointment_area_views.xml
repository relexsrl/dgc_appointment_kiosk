<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- DGC List View (standalone — used only from our action) -->
    <record id="dgc_appointment_area_view_list" model="ir.ui.view">
        <field name="name">appointment.type.dgc.list</field>
        <field name="model">appointment.type</field>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="dgc_code"/>
                <field name="dgc_location"/>
                <field name="pending_turn_count"/>
                <field name="remaining_turns_today"/>
                <field name="dgc_max_counters"/>
                <field name="active" column_invisible="True"/>
                <field name="is_dgc_area" column_invisible="True"/>
            </list>
        </field>
    </record>

    <!-- Inherit native appointment.type form — ADD DGC fields without removing anything -->
    <record id="dgc_appointment_area_view_form" model="ir.ui.view">
        <field name="name">appointment.type.dgc.form.inherit</field>
        <field name="model">appointment.type</field>
        <field name="inherit_id" ref="appointment.appointment_type_view_form"/>
        <field name="arch" type="xml">

            <!-- Hidden field for DGC flag -->
            <xpath expr="//field[@name='active']" position="after">
                <field name="is_dgc_area" invisible="1"/>
            </xpath>

            <!-- DGC fields in left_details group -->
            <xpath expr="//group[@name='left_details']" position="inside">
                <field name="dgc_code" invisible="not is_dgc_area"/>
                <field name="dgc_location" invisible="not is_dgc_area"/>
                <field name="dgc_max_counters" invisible="not is_dgc_area"/>
            </xpath>

            <!-- DGC company in right_details group -->
            <xpath expr="//group[@name='right_details']" position="inside">
                <field name="company_id" groups="base.group_multi_company"
                       invisible="not is_dgc_area"/>
                <field name="dgc_color" widget="color_picker" invisible="not is_dgc_area"/>
            </xpath>

            <!-- DGC tab in notebook -->
            <xpath expr="//notebook" position="inside">
                <page string="DGC Turnero" name="dgc_turnero" invisible="not is_dgc_area">
                    <group string="Mensaje de bienvenida">
                        <field name="dgc_welcome_message" nolabel="1"/>
                    </group>
                    <group string="Estadísticas del día">
                        <field name="pending_turn_count"/>
                        <field name="max_daily_turns"/>
                        <field name="remaining_turns_today"/>
                    </group>
                </page>
            </xpath>

        </field>
    </record>

    <!-- DGC Search View -->
    <record id="dgc_appointment_area_view_search" model="ir.ui.view">
        <field name="name">appointment.type.dgc.search</field>
        <field name="model">appointment.type</field>
        <field name="arch" type="xml">
            <search>
                <field name="name"/>
                <field name="dgc_code"/>
                <field name="dgc_location"/>
                <filter name="active" string="Activas" domain="[('active', '=', True)]"/>
                <filter name="inactive" string="Inactivas" domain="[('active', '=', False)]"/>
            </search>
        </field>
    </record>

    <!-- Action (filters to DGC areas only, uses list override + inherited form) -->
    <record id="action_dgc_appointment_area" model="ir.actions.act_window">
        <field name="name">Áreas de Atención</field>
        <field name="res_model">appointment.type</field>
        <field name="view_mode">list,form</field>
        <field name="domain">[('is_dgc_area', '=', True)]</field>
        <field name="context">{'default_is_dgc_area': True, 'default_category': 'recurring'}</field>
        <field name="search_view_id" ref="dgc_appointment_area_view_search"/>
        <field name="view_ids" eval="[(5, 0, 0),
            (0, 0, {'view_mode': 'list', 'view_id': ref('dgc_appointment_area_view_list')})]"/>
    </record>

</odoo>
