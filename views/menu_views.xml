<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Root Menu -->
    <menuitem id="menu_dgc_turnero_root"
              name="Turnero DGC"
              web_icon="dgc_appointment_kiosk,static/description/icon.png"
              sequence="200"
              groups="dgc_appointment_kiosk.group_dgc_admin,dgc_appointment_kiosk.group_dgc_area_manager,dgc_appointment_kiosk.group_dgc_operator"/>

    <!-- Panel Admin -->
    <menuitem id="menu_dgc_admin_panel"
              name="Panel Admin"
              parent="menu_dgc_turnero_root"
              action="action_dgc_admin_dashboard"
              sequence="3"
              groups="dgc_appointment_kiosk.group_dgc_admin,dgc_appointment_kiosk.group_dgc_area_manager"/>

    <!-- Panel Operador -->
    <menuitem id="menu_dgc_operator_panel"
              name="Panel Operador"
              parent="menu_dgc_turnero_root"
              action="action_dgc_operator_dashboard"
              sequence="5"
              groups="dgc_appointment_kiosk.group_dgc_operator"/>

    <!-- Turnos -->
    <menuitem id="menu_dgc_turnos"
              name="Turnos"
              parent="menu_dgc_turnero_root"
              action="action_dgc_appointment_turn"
              sequence="10"
              groups="dgc_appointment_kiosk.group_dgc_admin,dgc_appointment_kiosk.group_dgc_area_manager,dgc_appointment_kiosk.group_dgc_operator"/>

    <!-- Áreas -->
    <menuitem id="menu_dgc_areas"
              name="Áreas"
              parent="menu_dgc_turnero_root"
              action="action_dgc_appointment_area"
              sequence="20"
              groups="dgc_appointment_kiosk.group_dgc_admin,dgc_appointment_kiosk.group_dgc_area_manager"/>

    <!-- Derivaciones -->
    <menuitem id="menu_dgc_derivaciones"
              name="Derivaciones"
              parent="menu_dgc_turnero_root"
              action="action_dgc_appointment_derivation"
              sequence="30"
              groups="dgc_appointment_kiosk.group_dgc_admin,dgc_appointment_kiosk.group_dgc_area_manager,dgc_appointment_kiosk.group_dgc_operator"/>

    <!-- Estadísticas -->
    <menuitem id="menu_dgc_dashboard"
              name="Estadísticas"
              parent="menu_dgc_turnero_root"
              action="action_dgc_dashboard"
              sequence="40"
              groups="dgc_appointment_kiosk.group_dgc_admin,dgc_appointment_kiosk.group_dgc_area_manager,dgc_appointment_kiosk.group_dgc_operator"/>

    <!-- Configuración -->
    <menuitem id="menu_dgc_config"
              name="Configuración"
              parent="menu_dgc_turnero_root"
              sequence="100"
              groups="dgc_appointment_kiosk.group_dgc_admin"/>

    <record id="action_dgc_config_settings" model="ir.actions.act_window">
        <field name="name">Ajustes del Turnero</field>
        <field name="res_model">res.config.settings</field>
        <field name="view_mode">form</field>
        <field name="target">main</field>
        <field name="context">{'module': 'dgc_appointment_kiosk'}</field>
    </record>

    <menuitem id="menu_dgc_config_settings"
              name="Ajustes"
              parent="menu_dgc_config"
              action="action_dgc_config_settings"
              sequence="10"
              groups="dgc_appointment_kiosk.group_dgc_admin"/>

</odoo>
