<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Graph View -->
    <record id="dgc_appointment_turn_view_graph" model="ir.ui.view">
        <field name="name">dgc.appointment.turn.graph</field>
        <field name="model">dgc.appointment.turn</field>
        <field name="arch" type="xml">
            <graph string="Turnos" type="bar">
                <field name="area_id"/>
                <field name="state" type="col"/>
            </graph>
        </field>
    </record>

    <!-- Pivot View -->
    <record id="dgc_appointment_turn_view_pivot" model="ir.ui.view">
        <field name="name">dgc.appointment.turn.pivot</field>
        <field name="model">dgc.appointment.turn</field>
        <field name="arch" type="xml">
            <pivot string="Análisis de Turnos">
                <field name="area_id" type="row"/>
                <field name="state" type="col"/>
                <field name="duration" type="measure"/>
                <field name="wait_time" type="measure"/>
            </pivot>
        </field>
    </record>

    <!-- Statistics Action (graph/pivot) -->
    <record id="action_dgc_dashboard" model="ir.actions.act_window">
        <field name="name">Estadísticas</field>
        <field name="res_model">dgc.appointment.turn</field>
        <field name="view_mode">graph,pivot</field>
    </record>

    <!-- Operator Dashboard (client action) -->
    <record id="action_dgc_operator_dashboard" model="ir.actions.client">
        <field name="name">Panel del Operador</field>
        <field name="tag">dgc_operator_dashboard</field>
    </record>

</odoo>
