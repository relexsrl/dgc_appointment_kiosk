<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="dgc_turn_create_wizard_view_form" model="ir.ui.view">
        <field name="name">dgc.turn.create.wizard.form</field>
        <field name="model">dgc.turn.create.wizard</field>
        <field name="arch" type="xml">
            <form string="Crear Turno Manual">
                <group>
                    <field name="citizen_dni" placeholder="Ej: 12345678"/>
                    <field name="citizen_name"/>
                    <field name="citizen_email"/>
                    <field name="area_id"/>
                    <field name="available_area_ids" invisible="1"/>
                    <field name="notes"/>
                </group>
                <footer>
                    <button name="action_create_turn" type="object" string="Crear Turno"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_dgc_turn_create_wizard" model="ir.actions.act_window">
        <field name="name">Crear Turno Manual</field>
        <field name="res_model">dgc.turn.create.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

</odoo>
