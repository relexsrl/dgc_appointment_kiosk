<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="dgc_turn_derive_wizard_view_form" model="ir.ui.view">
        <field name="name">dgc.turn.derive.wizard.form</field>
        <field name="model">dgc.turn.derive.wizard</field>
        <field name="arch" type="xml">
            <form string="Derivar Turno">
                <group>
                    <field name="turn_id" readonly="1"/>
                    <field name="to_area_id" domain="[('is_dgc_area', '=', True), ('active', '=', True)]"/>
                    <field name="reason"/>
                </group>
                <footer>
                    <button name="action_derive" type="object" string="Derivar"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
