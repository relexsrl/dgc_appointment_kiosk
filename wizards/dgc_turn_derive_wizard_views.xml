<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="dgc_turn_derive_wizard_view_form" model="ir.ui.view">
        <field name="name">dgc.turn.derive.wizard.form</field>
        <field name="model">dgc.turn.derive.wizard</field>
        <field name="arch" type="xml">
            <form string="Derivar Turno">
                <field name="turn_id" invisible="1"/>
                <sheet>
                    <group>
                        <group string="Turno Origen">
                            <field name="source_turn_number"/>
                            <field name="source_citizen_dni"/>
                            <field name="source_citizen_name"/>
                            <field name="source_area_id"/>
                        </group>
                        <group string="Derivar a">
                            <field name="to_area_id"
                                   options="{'no_create': True}"/>
                            <field name="reason" placeholder="Motivo de la derivación..."/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_derive" type="object" string="Derivar"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
