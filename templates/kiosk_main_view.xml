<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="kiosk_main_view" name="Kiosco DGC - Turnos">
        <html lang="es">
            <head>
                <title>Turnero DGC - Kiosco</title>
                <meta charset="utf-8"/>
                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
                <t t-call-assets="dgc_appointment_kiosk.assets_kiosk"/>
                <style>
                    :root {
                        --dgc-primary: <t t-out="brand_primary_color or '#1A237E'"/>;
                    }
                </style>
            </head>
            <body>
                <div class="kiosk-container"
                     data-timeout="[timeout]"
                     data-require-email="[require_email]"
                     data-show-notes="[show_notes]"
                     t-att-data-timeout="timeout"
                     t-att-data-require-email="require_email"
                     t-att-data-show-notes="show_notes">

                    <!-- Header -->
                    <div class="kiosk-header">
                        <t t-if="brand_logo_url">
                            <img t-att-src="brand_logo_url" alt="Logo" class="kiosk-logo"/>
                        </t>
                        <h1 class="kiosk-title">Sistema de Turnos</h1>
                        <p class="kiosk-subtitle">Dirección General de Catastro</p>
                    </div>

                    <!-- Step 0: Welcome / Action Selection -->
                    <div class="step active" id="step-0">
                        <div class="welcome-panel">
                            <div class="welcome-actions">
                                <button class="btn-welcome btn-welcome-primary" id="btn-new-turn" aria-label="Sacar nuevo turno">
                                    <span class="btn-welcome-icon">&#43;</span>
                                    <span class="btn-welcome-label">Sacar Nuevo Turno</span>
                                </button>
                                <button class="btn-welcome btn-welcome-secondary" id="btn-check-turn" aria-label="Consultar mi turno">
                                    <span class="btn-welcome-icon">&#63;</span>
                                    <span class="btn-welcome-label">Consultar mi Turno</span>
                                </button>
                            </div>
                        </div>
                    </div>

                    <!-- Step 1: DNI Input -->
                    <div class="step" id="step-1">
                        <h2 tabindex="-1">Ingrese su DNI o CUIT</h2>
                        <div class="doc-type-switch d-flex justify-content-center align-items-center gap-3 mb-3" id="doc-type-switch-1">
                            <span class="doc-type-label active" data-type="dni">DNI</span>
                            <label class="switch">
                                <input type="checkbox" id="doc-type-toggle-1"/>
                                <span class="slider round"></span>
                            </label>
                            <span class="doc-type-label" data-type="cuit">CUIT</span>
                        </div>
                        <div class="dni-display">
                            <input type="text" id="dni-input" readonly="readonly"
                                   placeholder="Ingrese su DNI"
                                   class="dni-field" maxlength="8"
                                   role="status" aria-live="polite" aria-label="Número de documento ingresado"/>
                            <div id="dni-validation" class="dni-validation neutral"></div>
                        </div>
                        <div class="numpad" role="group" aria-label="Teclado numérico">
                            <button class="numpad-btn" data-value="1" aria-label="Número 1">1</button>
                            <button class="numpad-btn" data-value="2" aria-label="Número 2">2</button>
                            <button class="numpad-btn" data-value="3" aria-label="Número 3">3</button>
                            <button class="numpad-btn" data-value="4" aria-label="Número 4">4</button>
                            <button class="numpad-btn" data-value="5" aria-label="Número 5">5</button>
                            <button class="numpad-btn" data-value="6" aria-label="Número 6">6</button>
                            <button class="numpad-btn" data-value="7" aria-label="Número 7">7</button>
                            <button class="numpad-btn" data-value="8" aria-label="Número 8">8</button>
                            <button class="numpad-btn" data-value="9" aria-label="Número 9">9</button>
                            <button class="numpad-btn numpad-clear" data-value="clear" aria-label="Borrar">Borrar</button>
                            <button class="numpad-btn" data-value="0" aria-label="Número 0">0</button>
                            <button class="numpad-btn numpad-next numpad-next-disabled" data-value="next" id="numpad-next-1" disabled="disabled" aria-label="Siguiente">Siguiente</button>
                        </div>
                        <button class="btn-back" id="btn-back-1" aria-label="Volver">Volver</button>
                        <div class="error-message" id="dni-error" style="display:none;" aria-live="polite"></div>
                    </div>

                    <!-- Step 2: Area Selection -->
                    <div class="step" id="step-2">
                        <h2 tabindex="-1">Seleccione el área</h2>
                        <div class="area-list" id="area-list">
                            <!-- Areas loaded dynamically -->
                        </div>
                        <button class="btn-back" id="btn-back-2" aria-label="Volver">Volver</button>
                        <div class="error-message" id="area-error" style="display:none;" aria-live="polite"></div>
                    </div>

                    <!-- Step 3: Confirmation -->
                    <div class="step" id="step-3">
                        <div class="confirmation-panel">
                            <div class="confirmation-icon"></div>
                            <h2 tabindex="-1">¡Turno generado!</h2>
                            <div class="turn-number-display" id="turn-number-display" aria-live="polite"></div>
                            <div class="turn-area-display" id="turn-area-display"></div>
                            <div class="turn-location" id="turn-location"></div>
                            <div class="turn-queue-info" id="turn-queue-info">
                                <div class="queue-stat">
                                    <span class="queue-label">Turnos en espera</span>
                                    <span class="queue-value" id="turns-ahead-display">—</span>
                                </div>
                                <div class="queue-stat">
                                    <span class="queue-label">Tiempo estimado</span>
                                    <span class="queue-value" id="estimated-wait-display">—</span>
                                </div>
                            </div>
                            <p class="countdown-text">
                                Volviendo al inicio en <span id="countdown">10</span> segundos
                            </p>
                        </div>
                    </div>

                    <!-- Step Check: DNI input for turn lookup -->
                    <div class="step" id="step-check">
                        <h2 tabindex="-1">Consultar mi Turno</h2>
                        <p class="step-hint">Ingrese su DNI o CUIT para buscar su turno activo</p>
                        <div class="doc-type-switch d-flex justify-content-center align-items-center gap-3 mb-3" id="doc-type-switch-check">
                            <span class="doc-type-label active" data-type="dni">DNI</span>
                            <label class="switch">
                                <input type="checkbox" id="doc-type-toggle-check"/>
                                <span class="slider round"></span>
                            </label>
                            <span class="doc-type-label" data-type="cuit">CUIT</span>
                        </div>
                        <div class="dni-display">
                            <input type="text" id="check-dni-input" readonly="readonly"
                                   placeholder="Ingrese su DNI"
                                   class="dni-field" maxlength="8"
                                   role="status" aria-live="polite" aria-label="Número de documento ingresado"/>
                            <div id="check-dni-validation" class="dni-validation neutral"></div>
                        </div>
                        <div class="numpad" role="group" aria-label="Teclado numérico">
                            <button class="numpad-btn" data-value="1" aria-label="Número 1">1</button>
                            <button class="numpad-btn" data-value="2" aria-label="Número 2">2</button>
                            <button class="numpad-btn" data-value="3" aria-label="Número 3">3</button>
                            <button class="numpad-btn" data-value="4" aria-label="Número 4">4</button>
                            <button class="numpad-btn" data-value="5" aria-label="Número 5">5</button>
                            <button class="numpad-btn" data-value="6" aria-label="Número 6">6</button>
                            <button class="numpad-btn" data-value="7" aria-label="Número 7">7</button>
                            <button class="numpad-btn" data-value="8" aria-label="Número 8">8</button>
                            <button class="numpad-btn" data-value="9" aria-label="Número 9">9</button>
                            <button class="numpad-btn numpad-clear" data-value="clear" aria-label="Borrar">Borrar</button>
                            <button class="numpad-btn" data-value="0" aria-label="Número 0">0</button>
                            <button class="numpad-btn numpad-next numpad-next-disabled" data-value="next" id="numpad-next-check" disabled="disabled" aria-label="Consultar">Consultar</button>
                        </div>
                        <button class="btn-back" id="btn-back-check" aria-label="Volver">Volver</button>
                        <div class="error-message" id="check-dni-error" style="display:none;" aria-live="polite"></div>
                    </div>

                    <!-- Step Check Result: Turn status display -->
                    <div class="step" id="step-check-result">
                        <div id="check-result-content">
                            <!-- Dynamically rendered -->
                        </div>
                        <div class="check-result-actions">
                            <button class="btn-back" id="btn-back-check-result" aria-label="Volver al inicio">Volver al inicio</button>
                            <p class="countdown-text">
                                Volviendo al inicio en <span id="check-result-countdown">30</span> segundos
                            </p>
                        </div>
                    </div>

                    <!-- Error Step -->
                    <div class="step" id="step-error">
                        <div class="error-panel">
                            <div class="error-icon"></div>
                            <h2 id="error-title" tabindex="-1">Error</h2>
                            <p id="error-detail"></p>
                            <button class="btn-primary" id="btn-retry" aria-label="Reintentar">Reintentar</button>
                        </div>
                    </div>

                </div>
            </body>
        </html>
    </template>
</odoo>
